[colors]
bg              = #282c34
active-bg       = #3e4452
text            = #abb2bf
active-text     = ${colors.text}
highlight       = #61afef
highlight-text  = ${colors.bg}
urgent          = #e5c07b
urgent-text     = ${colors.bg}

[bar/base]
width = 100%
height = 25
fixed-center = true
wm-restack = bspwm

background = ${colors.bg}
foreground = ${colors.text}
border-top = 1
border-top-color = ${colors.bg}
border-bottom = 1
border-bottom-color = ${colors.bg}

padding-left = 0
padding-right = 2

module-margin-left = 1
module-margin-right = 2

font-0 = Roboto Condensed:size=11;3
font-1 = Font Awesome 5 Free:size=10;3
font-2 = Font Awesome 5 Free Solid:size=10;3
font-3 = Font Awesome 5 Brands:size=10;3

cursor-click = pointer

locale = pl_PL.UTF-8
monitor-exact = true
monitor-strict = true

[bar/primary]
inherit = bar/base
monitor = ${env:MONITOR:}

modules-left = bspwm xwindow
modules-center = date
modules-right = mpris updates redshift backlight pulseaudio bluetooth wlan eth battery

tray-position = right
tray-padding = 2

[bar/secondary]
inherit = bar/base
monitor = ${env:MONITOR:}

modules-left = bspwm
modules-center =
modules-right =

tray-position = none

[module/bspwm]
type = internal/bspwm
format = <label-mode> <label-state>

; Various settings
pin-workspaces = true
inline-mode = false
enable-click = true
enable-scroll = false
reverse-scroll = false
fuzzy-match = false

; Workspace icons
ws-icon-0 = 1;ÔČ©
ws-icon-1 = 2;ÔĄ†
ws-icon-2 = 3;ÔĄ°
ws-icon-3 = 4;ÔĀľ
ws-icon-4 = 5;ÔČ¨
ws-icon-5 = 6;ÔČ¨
ws-icon-6 = 7;ÔČ¨
ws-icon-7 = 8;ÔÖĀ
ws-icon-8 = 9;ÔÉ†
ws-icon-9 = 10;ÔÜľ
ws-icon-default = ÔČ¨

; Occupied, not focused workspace
label-occupied = %name% %icon%
label-occupied-background = ${colors.bg}
label-occupied-foreground = ${colors.text}
label-occupied-padding = 2

; Active workspace on focused monitor
label-focused = %name% %icon%
label-focused-background = ${colors.highlight}
label-focused-foreground = ${colors.highlight-text}
label-focused-padding = 2

; Inactive workspace on any monitor
label-dimmed-focused-background = ${colors.active-bg}
label-dimmed-focused-foreground = ${colors.active-text}

; Urgent workspace
label-urgent = %name% %icon%
label-urgent-background = ${colors.urgent}
label-urgent-foreground = ${colors.urgent-text}
label-urgent-padding = 2

; Do not show empty workspaces at all
label-empty =


[module/xwindow]
type = internal/xwindow
label = %title:0:55:...%

[module/mpris]
type = custom/script
exec = ~/.config/polybar/modules/mpris.sh --icon-playing ÔÖĄ --icon-paused Ôäč
interval = 5
label = %output:0:35:...%
click-left = playerctl play-pause

[module/updates]
type = custom/script
interval = 600
exec = ~/.config/polybar/modules/updates.sh
label = ÔÄô %output%

[module/redshift]
type = custom/script
interval = 15
exec = ~/.config/polybar/modules/redshift.sh --icon-on ÔÉę --icon-off ÔÉę
label = %output%
click-left = ~/.config/polybar/modules/redshift.sh toggle

[module/date]
type = internal/date
interval = 15

date = %e %b
time = %H:%M
label = ÔÄó %date%, %time%

[module/backlight]
type = custom/script
exec = ~/.config/polybar/modules/light.sh
tail = true
scroll-up = ~/.config/polybar/modules/light.sh inc
scroll-down = ~/.config/polybar/modules/light.sh dec
label = ÔÜÖ %output%%

[module/pulseaudio]
type = internal/pulseaudio
use-ui-max = false
format-volume = <label-volume>
label-volume = ÔÄ® %percentage%%
label-muted = Ôö© %percentage%%

[module/bluetooth]
type = custom/script
exec = ~/.config/polybar/modules/bluetooth.sh
tail = true
label = Ôäď %output%

[module/wlan]
type = internal/network
interval = 3.0
interface = wlp2s0

label-connected = Ôáę %signal%% %essid%
format-disconnected =

[module/eth]
type = internal/network
interval = 3.0
interface = enp1s0

label-connected = ÔõŅ eth
format-disconnected =

[module/battery]
type = internal/battery

battery = BAT0
adapter = AC
full-at = 100

time-format = %H:%M

format-full = <ramp-capacity> <label-full>
format-charging = ÔÉß <label-charging>
format-discharging = <ramp-capacity> <label-discharging>

label-full = %percentage%%
label-charging = %percentage%%
label-discharging = %percentage%%

ramp-capacity-0 = ÔČĄ
ramp-capacity-1 = ÔČÉ
ramp-capacity-2 = ÔČā
ramp-capacity-3 = ÔČĀ
ramp-capacity-4 = ÔČÄ

